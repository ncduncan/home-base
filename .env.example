# Home-Base local development environment
# Copy to .env and fill in real values (never commit .env)

# Google OAuth token path (generated by scripts/generate_token.py)
GOOGLE_TOKEN_PATH=token.json

# Asana
ASANA_PAT=your-asana-personal-access-token
ASANA_WORKSPACE_GID=your-workspace-gid
# ASANA_PROJECT_GID=optional-project-gid

# OpenWeatherMap (free tier works)
OPENWEATHERMAP_API_KEY=your-owm-api-key

# Anthropic / Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email + calendar
BRIEFING_EMAIL_TO=ncduncan@gmail.com
WORK_EMAIL=Nathaniel.duncan@geaerospace.com

# Feature flags
BRIEFING_DRY_RUN=true   # Set to false for a real send
EINK_ENABLED=false
