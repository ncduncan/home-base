<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Home-Base Briefing</title>
  <style>
    /* ── Reset ─────────────────────────────────────────────────────── */
    body {
      margin: 0; padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
                   'Helvetica Neue', Arial, sans-serif;
      background: #f0f2f5;
      color: #1a1a1a;
      -webkit-font-smoothing: antialiased;
    }
    * { box-sizing: border-box; }

    /* ── Wrapper ────────────────────────────────────────────────────── */
    .wrapper { max-width: 640px; margin: 24px auto; }

    /* ── Header ─────────────────────────────────────────────────────── */
    .header {
      background: #111827;
      color: #fff;
      padding: 32px 40px 28px;
      border-radius: 12px 12px 0 0;
    }
    .header-eyebrow {
      font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
      text-transform: uppercase; color: #6b7280; margin-bottom: 6px;
    }
    .header h1 {
      margin: 0; font-size: 26px; font-weight: 700; letter-spacing: -0.5px;
    }
    .header .week-label {
      margin: 6px 0 0; font-size: 14px; color: #9ca3af;
    }

    /* ── Card ────────────────────────────────────────────────────────── */
    .card {
      background: #fff;
      padding: 28px 40px;
      border-left: 1px solid #e5e7eb;
      border-right: 1px solid #e5e7eb;
    }
    .card + .card { border-top: 1px solid #f3f4f6; }
    .card:last-of-type {
      border-radius: 0 0 12px 12px;
      border-bottom: 1px solid #e5e7eb;
    }

    /* ── Section header ─────────────────────────────────────────────── */
    .section-label {
      font-size: 10px; font-weight: 700; letter-spacing: 1.8px;
      text-transform: uppercase; color: #9ca3af; margin: 0 0 16px;
    }

    /* ── Narrative ──────────────────────────────────────────────────── */
    .narrative {
      font-size: 15px; line-height: 1.75; color: #374151;
    }
    .narrative p { margin: 0 0 14px; }
    .narrative p:last-child { margin-bottom: 0; }

    /* ── Calendar events ────────────────────────────────────────────── */
    .events-table {
      width: 100%; border-collapse: collapse; font-size: 13.5px;
    }
    .events-table tr + tr td { border-top: 1px solid #f3f4f6; }
    .events-table td { padding: 9px 6px; vertical-align: top; }
    .evt-day {
      white-space: nowrap; color: #6b7280; font-size: 12px;
      font-weight: 600; width: 110px; padding-top: 10px;
    }
    .evt-time {
      white-space: nowrap; color: #9ca3af; font-size: 11.5px;
      width: 95px; padding-top: 11px;
    }
    .evt-title { font-weight: 500; color: #111827; }
    .evt-loc { font-size: 12px; color: #9ca3af; margin-top: 2px; }
    .amion-badge {
      display: inline-block;
      background: #dbeafe; color: #1d4ed8;
      font-size: 10px; font-weight: 600; letter-spacing: 0.5px;
      padding: 1px 6px; border-radius: 4px; margin-left: 6px;
      vertical-align: middle;
    }

    /* ── Asana tasks ────────────────────────────────────────────────── */
    .task-row {
      display: flex; justify-content: space-between; align-items: baseline;
      padding: 10px 0; border-bottom: 1px solid #f3f4f6;
      gap: 12px;
    }
    .task-row:last-child { border-bottom: none; padding-bottom: 0; }
    .task-name {
      font-size: 14px; font-weight: 500; color: #111827;
      text-decoration: none;
    }
    .task-name:hover { text-decoration: underline; }
    .task-meta { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .task-due {
      font-size: 12px; white-space: nowrap; font-weight: 500;
    }
    .task-due.overdue { color: #dc2626; }
    .task-due.soon    { color: #d97706; }
    .task-due.ok      { color: #6b7280; }
    .empty-state { font-size: 14px; color: #9ca3af; }

    /* ── Weather grid ───────────────────────────────────────────────── */
    .weather-grid {
      display: flex; gap: 6px; flex-wrap: wrap;
    }
    .weather-card {
      flex: 1; min-width: 72px; max-width: 84px;
      background: #f9fafb; border: 1px solid #e5e7eb;
      border-radius: 10px; padding: 10px 8px; text-align: center;
    }
    .weather-card.rain { background: #eff6ff; border-color: #bfdbfe; }
    .weather-card.cold { background: #f0f9ff; border-color: #bae6fd; }
    .weather-card.hot  { background: #fff7ed; border-color: #fed7aa; }
    .wday  { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.5px; text-transform: uppercase; }
    .wdesc { font-size: 10.5px; color: #6b7280; margin: 4px 0; line-height: 1.3; min-height: 28px; }
    .wtemps { font-size: 13.5px; font-weight: 700; color: #111827; }
    .wtemps .lo { color: #9ca3af; font-weight: 400; }
    .wprecip { font-size: 10.5px; color: #3b82f6; margin-top: 4px; }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .footer {
      margin-top: 16px;
      font-size: 11px; color: #9ca3af; text-align: center;
      padding-bottom: 24px;
    }

    /* ── Responsive ─────────────────────────────────────────────────── */
    @media (max-width: 480px) {
      .card, .header { padding-left: 24px; padding-right: 24px; }
      .weather-card { min-width: 60px; }
    }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- ── Header ───────────────────────────────────────────────────── -->
  <div class="header">
    <div class="header-eyebrow">Home-Base</div>
    <h1>Good morning, Nat.</h1>
    <div class="week-label">
      Week of {{ data.week_start.strftime('%B %-d') }}–{{ data.week_end.strftime('%B %-d, %Y') }}
    </div>
  </div>

  <!-- ── AI Narrative ──────────────────────────────────────────────── -->
  <div class="card">
    <p class="section-label">Your Week Ahead</p>
    <div class="narrative">
      {% for para in data.narrative.split('\n\n') %}
        {% if para.strip() %}<p>{{ para.strip() }}</p>{% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- ── Calendar Events ───────────────────────────────────────────── -->
  <div class="card">
    <p class="section-label">Calendar</p>
    {% if data.calendar_events %}
    <table class="events-table">
      {% for event in data.calendar_events %}
      <tr>
        <td class="evt-day">{{ event.start.strftime('%a %-d %b') }}</td>
        <td class="evt-time">
          {% if event.all_day %}
            all day
          {% else %}
            {{ event.start.strftime('%-I:%M%p')|lower }}
          {% endif %}
        </td>
        <td>
          <div class="evt-title">
            {{ event.title }}
            {% if event.is_amion %}<span class="amion-badge">AMION</span>{% endif %}
          </div>
          {% if event.location %}
          <div class="evt-loc">📍 {{ event.location }}</div>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </table>
    {% else %}
    <p class="empty-state">Nothing on the calendar this week.</p>
    {% endif %}
  </div>

  <!-- ── Asana Tasks ───────────────────────────────────────────────── -->
  <div class="card">
    <p class="section-label">Before the Weekend's Over</p>
    {% if data.asana_tasks %}
      {% for task in data.asana_tasks %}
      <div class="task-row">
        <div>
          <a class="task-name" href="{{ task.url }}" target="_blank">{{ task.name }}</a>
          {% if task.project %}<div class="task-meta">{{ task.project }}</div>{% endif %}
        </div>
        {% if task.due_on %}
          {% set delta = (task.due_on - today).days %}
          {% if delta < 0 %}
            <span class="task-due overdue">{{ task.due_on.strftime('%b %-d') }} (overdue)</span>
          {% elif delta <= 1 %}
            <span class="task-due soon">{{ task.due_on.strftime('%b %-d') }}</span>
          {% else %}
            <span class="task-due ok">{{ task.due_on.strftime('%b %-d') }}</span>
          {% endif %}
        {% else %}
          <span class="task-due ok">No due date</span>
        {% endif %}
      </div>
      {% endfor %}
    {% else %}
    <p class="empty-state">Nothing overdue — inbox zero. 🎉</p>
    {% endif %}
  </div>

  <!-- ── Boston Weather ────────────────────────────────────────────── -->
  <div class="card">
    <p class="section-label">Boston Weather</p>
    {% if data.weather %}
    <div class="weather-grid">
      {% for w in data.weather %}
        {% set card_class = '' %}
        {% if w.precipitation_chance >= 50 %}{% set card_class = 'rain' %}
        {% elif w.high_f < 32 %}{% set card_class = 'cold' %}
        {% elif w.high_f > 85 %}{% set card_class = 'hot' %}{% endif %}
      <div class="weather-card {{ card_class }}">
        <div class="wday">{{ w.date.strftime('%a') }}</div>
        <div class="wdesc">{{ w.description }}</div>
        <div class="wtemps">{{ w.high_f|int }}° <span class="lo">{{ w.low_f|int }}°</span></div>
        {% if w.precipitation_chance > 15 %}
        <div class="wprecip">💧{{ w.precipitation_chance }}%</div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="empty-state">Weather data unavailable.</p>
    {% endif %}
  </div>

</div><!-- /wrapper -->

<div class="footer">
  Generated {{ data.generated_at.strftime('%B %-d, %Y at %-I:%M %p ET') }} by Home-Base
</div>

</body>
</html>
