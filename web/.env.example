# Copy this file to .env.local and fill in your values.
# Get Supabase values from: Supabase → Project Settings → API
# Get Asana PAT from: https://app.asana.com/0/my-apps

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated emails allowed to log in (e.g. you@gmail.com,partner@gmail.com)
VITE_ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# Asana — PAT is embedded in the browser bundle (acceptable for private personal app)
VITE_ASANA_PAT=your_asana_personal_access_token
VITE_ASANA_WORKSPACE_GID=your_workspace_gid
