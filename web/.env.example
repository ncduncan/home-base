# Copy this file to .env.local and fill in your values.
# Get Supabase values from: Supabase → Project Settings → API
# Get Asana PAT from: https://app.asana.com/0/my-apps

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated emails allowed to log in (e.g. you@gmail.com,partner@gmail.com)
VITE_ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# Asana — PAT is embedded in the browser bundle (acceptable for private personal app)
VITE_ASANA_PAT=your_asana_personal_access_token
VITE_ASANA_WORKSPACE_GID=your_workspace_gid

# Owner display labels and emails — used to identify the two users in the UI
# and to route calendar invites between accounts. Falls back to "A" / "B" if
# unset and the email-based logic (Gus-care sync, default-owner) silently
# disables.
VITE_OWNER_NAT_LABEL=A
VITE_OWNER_CAITIE_LABEL=B
VITE_OWNER_NAT_EMAIL=user-a@example.com
VITE_OWNER_CAITIE_EMAIL=user-b@example.com

# Optional: a work email that personal calendar invites are forwarded to so
# they show up in another (e.g. M365/Outlook) calendar. Leave empty to disable.
VITE_NAT_WORK_EMAIL=
