# Copy this file to .env.local and fill in your values.
# Get Supabase values from: Supabase → Project Settings → API
# Get Asana PAT from: https://app.asana.com/0/my-apps

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Asana — PAT is embedded in the browser bundle (acceptable for private personal app)
VITE_ASANA_PAT=your_asana_personal_access_token
VITE_ASANA_WORKSPACE_GID=your_workspace_gid

# Owner identity AND login allowlist, all in one value.
# Format: comma-separated rows of  key:label:email[:workEmail]
#   key      = "nat" or "caitie" (stable internal discriminator)
#   label    = display name shown in the UI
#   email    = the Google account allowed to log in
#   workEmail = optional secondary email for invite forwarding (empty string ok)
#
# Example:
#   nat:User-A:a@example.com:a@work.example.com,caitie:User-B:b@example.com
#
# Falls back to "A" / "B" labels and an empty login allowlist if unset.
VITE_ALLOWED_EMAILS=nat:A:a@example.com,caitie:B:b@example.com
